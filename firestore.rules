rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /business_profiles/{document} {
      allow read, write: if true;
    }
    match /employee_invites/{document} {
      allow read, write: if true;
    }
    match /employees/{document} {
      allow read, write: if true;
    }
  }
}
